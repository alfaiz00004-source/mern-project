{
  "name": "full-stack",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start:backend": "node backend/server.js",
    "dev:backend": "nodemon backend/server.js",
    "start:frontend": "npm run dev --prefix frontend",
    "start:all": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "test:backend": "npm --prefix backend test -- --runInBand",
    "test:frontend": "npm --prefix frontend test -- --runInBand",
    "test:all": "npm run test:backend && npm run test:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
